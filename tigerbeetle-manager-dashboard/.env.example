NEXT_PUBLIC_APP_URL=http://localhost:3000
MANAGER_API_URL=http://localhost:8080
ADMIN_SECRET_KEY=changeme-admin-secret-key-12345

# Single-cluster (backward compat): id:host:port, comma-separated
# Default if unset: node-0:localhost:9090 through node-5:localhost:9095
#MANAGER_NODES=node-0:localhost:9090,node-1:localhost:9091,node-2:localhost:9092,node-3:localhost:9093,node-4:localhost:9094,node-5:localhost:9095

# Multi-cluster: clusterId=nodeId:host:port,...  with clusters pipe-separated (|)
# When set, MANAGER_CLUSTERS takes precedence over MANAGER_NODES.
# Node IDs become globally scoped: "{clusterId}~{nodeId}" (e.g. "prod~node-0").
#MANAGER_CLUSTERS=prod=node-0:10.0.0.1:9090,node-1:10.0.0.2:9090|staging=node-0:10.0.1.1:9090,node-1:10.0.1.2:9090
